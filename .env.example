# HealthWallet Pro - Environment Variables
# Copie para .env.local e preencha antes de rodar `npm run dev`

# --- Supabase (já existia) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clicksign (Assinatura Digital ICP-Brasil) ---
# Sandbox: https://sandbox.clicksign.com  |  Produção: https://app.clicksign.com
CLICKSIGN_API_URL=https://sandbox.clicksign.com
CLICKSIGN_ACCESS_TOKEN=
# URL pública do webhook (NÃO usar localhost — Clicksign não alcança)
CLICKSIGN_WEBHOOK_URL=https://healthwallet-site.netlify.app/api/clicksign/webhook

# --- CFM (Validação de CRM via SOAP Listamedicos) ---
# Obtenha a chave em https://crmvirtual.cfm.org.br (acesso restrito a empresas)
CFM_ACCESS_KEY=
# Opcional — endpoint customizado se você tiver contrato enterprise
CFM_LISTAMEDICOS_URL=https://ws.cfm.org.br/listamedicos/ws/Listamedicos

# --- Resend (Email transacional) ---
# Conta grátis: https://resend.com — 3000 emails/mês
RESEND_API_KEY=
RESEND_FROM=HealthWallet Pro <noreply@healthwallet.pro>

# --- App do Paciente ---
# URL base do app React do paciente (para deep links e botões do email)
HEALTHWALLET_APP_URL=https://app.healthwallet.pro
